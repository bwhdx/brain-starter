<?xml version="1.0" encoding="UTF-8"?>
<!-- setup.sh substitutes __HOME__ and installs this to ~/Library/LaunchAgents/ -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.openclaw.watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__HOME__/.openclaw/bin/watchdog.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>__HOME__/.openclaw/logs/watchdog-launchd.log</string>
    <key>StandardOutPath</key>
    <string>__HOME__/.openclaw/logs/watchdog-launchd.log</string>
</dict>
</plist>
